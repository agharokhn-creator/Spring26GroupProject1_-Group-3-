#Custom function to calculate key summary statistics 
#Returns: min, quartiles, median, mean, max, and SD
#my_summary_func
my_summary_func <- function(x) {
   summary_stats <- c( 
    Min = min(x),
    Q1 = quantile(x, 0.25),
    Median = median(x),
    Mean = mean(x),
    Q3 = quantile(x, 0.75),
    Max = max(x),
    SD = sd(x)
  )
   return(summary_stats)}
#Results of summaries of B1
#Apply custom summary function to each continuous variable
my_summary_func(HINTSData_2020_clean$Age)
my_summary_func(HINTSData_2020_clean$BMI)
my_summary_func(HINTSData_2020_clean$WeeklyMinutesModerateExercise)
my_summary_func(HINTSData_2020_clean$AvgDrinksPerWeek)

